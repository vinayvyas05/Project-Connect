# Server
PORT=5000

# Database
MONGO_URI=mongodb://localhost:27017/project-connect

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=10

# Team Invite Tokens
INVITE_TOKEN_SECRET=your_invite_token_secret_here
INVITE_TOKEN_EXPIRES_IN=7d

# Frontend URL (for CORS and invite links)
FRONTEND_URL=http://localhost:5173
